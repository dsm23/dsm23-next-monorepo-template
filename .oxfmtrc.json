{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "ignorePatterns": ["pnpm-lock.yaml"],
  "sortPackageJson": false,
  "overrides": [
    {
      "files": ["**/packages/ui/**"],
      "options": {
        "sortImports": {
          "newlinesBetween": false,
          "customGroups": [
            {
              "groupName": "react-libs",
              "elementNamePattern": ["react", "react-**"]
            },
            {
              "groupName": "type-react-libs",
              "elementNamePattern": ["@types/react", "@types/react-**"]
            },
            {
              "groupName": "clsx-libs",
              "elementNamePattern": ["clsx"]
            },
            {
              "groupName": "vitest-libs",
              "elementNamePattern": ["vitest", "@vitest-**"]
            }
          ],
          "groups": [
            "vitest-libs",
            ["react-libs", "type-react-libs"],
            "clsx-libs",
            ["value-builtin", "type-builtin"],
            ["value-external", "type-external"],
            ["value-internal", "type-internal"],
            ["value-parent", "value-sibling", "value-index"],
            "unknown",
            { "newlinesBetween": true },
            "style"
          ]
        },
        "sortTailwindcss": {
          "functions": ["clsx", "cn", "cva", "cx"],
          "stylesheet": "./packages/tailwind-config/globals.css"
        }
      }
    },
    {
      "files": ["**/apps/web/**"],
      "options": {
        "sortImports": {
          "newlinesBetween": false,
          "customGroups": [
            {
              "groupName": "react-libs",
              "elementNamePattern": ["react", "react-**"]
            },
            {
              "groupName": "type-react-libs",
              "elementNamePattern": ["@types/react", "@types/react-**"]
            },
            {
              "groupName": "clsx-libs",
              "elementNamePattern": ["clsx"]
            },
            {
              "groupName": "next-libs",
              "elementNamePattern": ["next", "next/**", "@next", "@next-**"]
            },
            {
              "groupName": "vitest-libs",
              "elementNamePattern": ["vitest", "@vitest-**"]
            }
          ],
          "groups": [
            "vitest-libs",
            ["react-libs", "type-react-libs"],
            "clsx-libs",
            "next-libs",
            ["value-builtin", "type-builtin"],
            ["value-external", "type-external"],
            ["value-internal", "type-internal"],
            ["value-parent", "value-sibling", "value-index"],
            "unknown",
            { "newlinesBetween": true },
            "style"
          ]
        },
        "sortTailwindcss": {
          "functions": ["clsx", "cn", "cva", "cx"],
          "stylesheet": "./apps/web/src/app/styles.css"
        }
      }
    }
  ]
}
