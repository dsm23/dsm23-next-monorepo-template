{
  "name": "web",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint:js": "oxlint . --report-unused-disable-directives --max-warnings 0",
    "lint:css": "stylelint \"**/*.css\" --max-warnings 0 --allow-empty-input --cache --cache-strategy=content --cache-location=.stylelintcache",
    "lint": "run-p lint:js lint:css",
    "check-types": "next typegen && tsc --noEmit",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@repo/ui": "workspace:*",
    "lucide-react": "1.17.0",
    "next": "16.2.9",
    "next-themes": "0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@playwright/test": "1.60.0",
    "@repo/oxlint-config": "workspace:*",
    "@repo/postcss-config": "workspace:*",
    "@repo/stylelint-config": "workspace:*",
    "@repo/tailwind-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "4.3.0",
    "@total-typescript/ts-reset": "0.6.1",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "dotenv": "17.4.2",
    "npm-run-all2": "9.0.1",
    "oxlint": "1.69.0",
    "oxlint-tsgolint": "0.23.0",
    "playwright": "1.60.0",
    "stylelint": "17.13.0",
    "tailwindcss": "4.3.0",
    "typed-query-selector": "2.12.2",
    "typescript": "6.0.3"
  }
}
