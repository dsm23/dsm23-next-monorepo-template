{
  "name": "storybook",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "storybook build",
    "dev": "storybook dev -p 6006",
    "lint:css": "stylelint \"**/*.css\" --max-warnings 0 --allow-empty-input",
    "lint:js": "oxlint . --report-unused-disable-directives --max-warnings 0",
    "lint": "run-p lint:js lint:css",
    "test": "vitest"
  },
  "dependencies": {
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.1.1",
    "@repo/oxlint-config": "workspace:*",
    "@repo/postcss-config": "workspace:*",
    "@repo/stylelint-config": "workspace:*",
    "@repo/tailwind-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@storybook/addon-a11y": "10.3.4",
    "@storybook/addon-docs": "10.3.4",
    "@storybook/addon-vitest": "10.3.4",
    "@storybook/nextjs-vite": "10.3.4",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/browser-playwright": "4.1.3",
    "npm-run-all2": "8.0.4",
    "oxlint": "1.59.0",
    "oxlint-tsgolint": "0.20.0",
    "playwright": "1.59.1",
    "storybook": "10.3.4",
    "stylelint": "17.6.0",
    "typescript": "6.0.2",
    "vitest": "4.1.3"
  }
}
