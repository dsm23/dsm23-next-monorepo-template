{
  "name": "@repo/oxlint-config",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "exports": {
    "./base": {
      "import": {
        "types": "./dist/base.d.mts",
        "default": "./dist/base.mjs"
      }
    },
    "./next": {
      "import": {
        "types": "./dist/next.d.mts",
        "default": "./dist/next.mjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.mts",
        "default": "./dist/react.mjs"
      }
    },
    "./storybook": {
      "import": {
        "types": "./dist/storybook.d.mts",
        "default": "./dist/storybook.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "eslint-plugin-storybook": "10.3.3",
    "tsdown": "0.21.7",
    "typescript": "6.0.2"
  },
  "peerDependencies": {
    "oxlint": "1.57.0",
    "oxlint-tsgolint": "0.17.4"
  }
}
