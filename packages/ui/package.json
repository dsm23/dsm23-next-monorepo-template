{
  "name": "@repo/ui",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "sideEffects": false,
  "files": [
    "dist/**",
    "dist"
  ],
  "exports": {
    "./components/button": {
      "import": {
        "types": "./dist/components/button/index.d.mts",
        "default": "./dist/components/button/index.mjs"
      }
    },
    "./components/dropdown-menu": {
      "import": {
        "types": "./dist/components/dropdown-menu/index.mts",
        "default": "./dist/components/dropdown-menu/index.mjs"
      }
    },
    "./components/theme-provider": {
      "import": {
        "types": "./dist/components/theme-provider/index.mts",
        "default": "./dist/components/theme-provider/index.mjs"
      }
    },
    "./hooks/use-mounted": {
      "import": {
        "types": "./dist/hooks/use-mounted/index.mts",
        "default": "./dist/hooks/use-mounted/index.mjs"
      }
    },
    "./lib/utils": {
      "import": {
        "types": "./dist/lib/utils/index.mts",
        "default": "./dist/lib/utils/index.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint:js": "oxlint . --max-warnings 0",
    "lint": "run-p lint:js",
    "check-types": "tsc --noEmit",
    "test": "vitest",
    "coverage": "vitest --coverage"
  },
  "dependencies": {
    "@base-ui/react": "1.5.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.17.0",
    "next-themes": "0.4.6",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@fast-check/vitest": "0.4.1",
    "@repo/oxlint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@storybook/nextjs-vite": "10.4.3",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.9.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.8",
    "jsdom": "29.1.1",
    "npm-run-all2": "9.0.1",
    "oxlint": "1.68.0",
    "oxlint-tsgolint": "0.23.0",
    "storybook": "10.4.3",
    "tsdown": "0.22.2",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  },
  "peerDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  }
}
